# Copy this to .env and fill in your values
# NEVER commit .env to version control

# Wallet private keys (add as many as you want)
# Each key should be a 0x-prefixed 32-byte hex private key
WALLET_KEY_0=0xYOUR_PRIVATE_KEY_HERE
WALLET_KEY_1=0xANOTHER_PRIVATE_KEY_HERE
WALLET_KEY_2=0xYET_ANOTHER_KEY_HERE

# Optional: override RPC URL (defaults to config/default.toml)
# BASE_RPC_URL=https://mainnet.base.org

# Optional: Telegram alerts
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
