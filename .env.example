# Copy this to .env and fill in your values
# NEVER commit .env to version control

# ── Option A: Seed phrase (recommended for Coinbase Smart Wallet) ──────────────
# The bot derives 5 accounts automatically (index 0–4) via BIP-44 m/44'/60'/0'/0/i
# Override count with WALLET_MNEMONIC_COUNT=10 if you want more derived wallets
WALLET_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# Optional: how many derived addresses to use (default 5)
# WALLET_MNEMONIC_COUNT=5

# ── Option B: Individual private keys (fallback if no mnemonic) ────────────────
# WALLET_KEY_0=0xYOUR_PRIVATE_KEY_HERE
# WALLET_KEY_1=0xANOTHER_PRIVATE_KEY_HERE

# ── Optional overrides ─────────────────────────────────────────────────────────
# BASE_RPC_URL=https://mainnet.base.org
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
